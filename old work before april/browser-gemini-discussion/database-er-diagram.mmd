erDiagram
    USERS ||--o{ PROJECTS : "creates & owns"
    PROJECTS ||--o{ SCANS : "has many"
    SCANS ||--o{ VERIFIED_VULNERABILITIES : "results in"

    USERS {
        uuid id PK "Managed by Supabase Auth"
        string email 
        timestamp created_at
    }

    PROJECTS {
        uuid id PK
        uuid user_id FK "Links project to specific user"
        string name "e.g., NodeJS Goof App"
        string repository_url "GitHub Link (NULL if local scan)"
        timestamp created_at
    }
    
    SCANS {
        uuid id PK
        uuid project_id FK
        string status "PENDING, SCANNING, COMPLETED, FAILED"
        string storage_path "Supabase Storage URL for local .zip uploads" 
        int total_findings "Raw count from Opengrep/Trivy"
        int verified_findings "Count after AI filtering"
        timestamp started_at
        timestamp completed_at
    }
    
    VERIFIED_VULNERABILITIES {
        uuid id PK
        uuid scan_id FK
        string file_path "e.g., src/auth.js"
        int line_number 
        string severity "HIGH, CRITICAL"
        string vulnerability_type "e.g., Hardcoded Secret"
        float ai_confidence_score "From Logic Agent (e.g., 0.95)"
        text logic_reasoning "The AI's explanation for WHY it is a bug"
        string wargame_status "e.g., 'Exploit Verified', 'Patch Applied'"
        text poc_script "Python code generated by Red Agent"
        text patch_code "Fix generated by Blue Agent"
        boolean is_resolved "Defaults to False. User toggles in UI."
    }